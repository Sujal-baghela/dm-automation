generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String               @id @default(cuid())
  email              String               @unique
  name               String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  auditLogs          AuditLog[]
  PlatformConnection PlatformConnection[]
  workflows          Workflow[]
  accounts           Account[]
  posts              Post[]
  mediaFiles         MediaFile[]
  inboxMessages      InboxMessage[]
  insights           ConversationInsight[]
  broadcastJobs      BroadcastJob[]
}

model Workflow {
  id        String    @id @default(cuid())
  userId    String
  name      String
  isActive  Boolean   @default(true)
  platforms String[]
  nodes     Json
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  triggers  Trigger[]
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Trigger {
  id         String   @id @default(cuid())
  workflowId String
  type       String
  pattern    String?
  platform   String?
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId, type, platform])
}

model Conversation {
  id               String    @id @default(cuid())
  platform         String
  externalId       String
  lastMessageAt    DateTime
  sessionExpiresAt DateTime?
  status           String    @default("active")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  messages         Message[]

  @@unique([platform, externalId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  direction      String
  content        String
  templateName   String?
  sentAt         DateTime     @default(now())
  status         String       @default("pending")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, sentAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  metadata  Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model PlatformConnection {
  id          String    @id
  userId      String
  platform    String
  accountId   String    @unique
  accessToken String
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  User        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([platform, accountId])
}

model Account {
  id           String    @id @default(cuid())
  userId       String
  platform     String
  externalId   String
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([platform, externalId])
}

model Post {
  id            String         @id @default(cuid())
  userId        String
  caption       String
  mediaUrls     String[]
  status        String         @default("draft")
  scheduledAt   DateTime?
  publishedAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  platformPosts PlatformPost[]
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PlatformPost {
  id         String   @id @default(cuid())
  postId     String
  platform   String
  externalId String?
  status     String   @default("pending")
  error      String?
  createdAt  DateTime @default(now())
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, platform])
}

model MediaFile {
  id        String   @id @default(cuid())
  userId    String
  url       String
  type      String
  filename  String
  size      Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InboxMessage {
  id         String               @id @default(cuid())
  userId     String
  platform   String
  externalId String
  senderId   String
  text       String?
  mediaUrl   String?
  isRead     Boolean              @default(false)
  isOutbound Boolean              @default(false)
  repliedAt  DateTime?
  createdAt  DateTime             @default(now())
  tags       String[]             @default([])
  insight    ConversationInsight?
  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, platform, isRead])
}

model ConversationInsight {
  id         String        @id @default(cuid())
  senderId   String
  userId     String
  sentiment  String        // "positive" | "neutral" | "negative"
  intent     String        // "interested" | "price-inquiry" | "support" | "objection" | "casual" | "ready-to-buy"
  tags       String[]
  summary    String
  analyzedAt DateTime      @default(now())
  messageId  String?       @unique
  message    InboxMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, senderId])
  @@index([userId, sentiment])
}

model BroadcastJob {
  id        String   @id @default(cuid())
  userId    String
  platform  String
  message   String
  sendAt    DateTime
  status    String   @default("pending")
  sentCount Int      @default(0)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status, sendAt])
}
